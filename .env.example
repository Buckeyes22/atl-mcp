# Agent Context Orchestrator MCP Server — environment variables
# Defaults are local-dev safe. Uncomment milestone credentials only after the
# corresponding feature flag is ready to enable.

# === Transport ===
# Which MCP transport to expose. Options: stdio | http | both
MCP_TRANSPORT=both

# Streamable HTTP transport (when MCP_TRANSPORT includes "http")
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_SESSION_TTL_SECONDS=3600
MCP_HTTP_SSE_KEEP_ALIVE_MS=25000
MCP_HTTP_MAX_CONCURRENT_SESSIONS=1000

# Mgmt API (always on; internal only)
MGMT_API_PORT=3001
MGMT_API_HOST=127.0.0.1

# Webhook ingress HTTP server
WEBHOOK_HTTP_PORT=3002
WEBHOOK_HTTP_HOST=0.0.0.0

# === Logging ===
# pino file output (NEVER stdout for stdio MCP servers — corrupts JSON-RPC frame)
LOG_LEVEL=info
LOG_FILE_PATH=./orchestrator.log

# === Deployment metadata ===
NODE_ENV=development
DEPLOYMENT_TIER=dev

# === Observability (M11 forward compatibility) ===
# SENTRY_DSN=
# SENTRY_ENV=
# OTEL_EXPORTER_OTLP_ENDPOINT=

# === Storage ===
# DATABASE_DEV_MODE=true            # PGlite when true; Postgres when false
# DATABASE_URL=.orchestrator/dev.pglite
# DATABASE_URL=postgres://orchestrator:dev@postgres:5432/orchestrator

# === Atlassian (M2) ===
# ATLASSIAN_AUTH_MODE=api_token        # api_token | oauth3lo
# ATLASSIAN_SITE_URL=https://your-site.atlassian.net
# JIRA_BASE_URL=https://your-site.atlassian.net
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# ATLASSIAN_EMAIL=you@example.com
# ATLASSIAN_API_TOKEN=ATATT...
# JIRA_PROJECT_KEY=PCO
# CONFLUENCE_SPACE_KEY=PCO

# === Atlassian OAuth 3LO callback ===
# Required when ATLASSIAN_AUTH_MODE=oauth3lo and using
# GET /oauth/atlassian/callback on the mgmt API.
# ATLASSIAN_OAUTH_CLIENT_ID=
# ATLASSIAN_OAUTH_CLIENT_SECRET=
# ATLASSIAN_OAUTH_STATE=<random state bound to the auth request>
# ATLASSIAN_OAUTH_PKCE_VERIFIER=<PKCE verifier bound to the auth request>
# ATLASSIAN_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/oauth/atlassian/callback
# ATLASSIAN_OAUTH_TOKEN_ENDPOINT=https://auth.atlassian.com/oauth/token

# === Token store (M1) ===
# TOKEN_MASTER_KEY=<base64 32-byte master key>

# === VCS — Bitbucket Cloud (M3) ===
# VCS_PROVIDER=bitbucket              # bitbucket | github
# BITBUCKET_USERNAME=your-bitbucket-username
# BITBUCKET_APP_PASSWORD=ATBB...
# BITBUCKET_WORKSPACE=your-workspace
# BITBUCKET_REPO_SLUG=your-repo

# === VCS — GitHub ===
# VCS_PROVIDER=github
# GITHUB_TOKEN=ghp_...
# GITHUB_OWNER=your-org-or-user
# GITHUB_REPO=your-repo

# === VCS — Worktree manager (M3; works against any local git repo) ===
# WORKTREE_SOURCE_REPO_PATH=/abs/path/to/your/repo
# WORKTREE_ROOT=/abs/path/to/.orchestrator/worktrees

# === Audit signing (M6a; ADR 0005) ===
# When AUDIT_SIGNING_PRIVKEY_PATH is set, the orchestrator loads the 32-byte
# ed25519 seed from that file (or generates + writes one with 0600 if absent),
# then registers the public key into the git-ref registry. When unset, signing
# uses an ephemeral key per process (dev/tests only — production must set this).
# AUDIT_SIGNING_PRIVKEY_PATH=~/.orchestrator/keys/private.key
# AUDIT_SIGNING_KEY_REGISTRY_REF=refs/orchestrator/keys
# AUDIT_SIGNING_REPO_PATH=/abs/path/to/your/repo

# === Queue (M6a) ===
# REDIS_URL=redis://localhost:6379

# === Webhook ingestion (M10) ===
# Required before MILESTONE_10_ENABLED=true; signatures are verified over rawBody.
# JIRA_WEBHOOK_SECRET=
# CONFLUENCE_WEBHOOK_SECRET=
# BITBUCKET_WEBHOOK_SECRET=
# GITHUB_WEBHOOK_SECRET=

# === Live/contract test toggles ===
# ATLASSIAN_LIVE_TEST=0
# BITBUCKET_LIVE_TEST=0
# UIO_LIVE_TEST=0

# === Partner toggles (off in M0; enable when their milestone lands) ===
# UIO_ENABLED=false
# UIO_BASE_URL=https://uio.example.com
# UIO_API_KEY=uio_...
# UIO_QDRANT_URL=http://localhost:6333
# UIO_QDRANT_API_KEY=
# UIO_DEFAULT_COLLECTION=uio_books_raw_v1

# === Agent memory vector recall (optional Qdrant) ===
# AGENT_MEMORY_VECTOR_ENABLED=false
# AGENT_MEMORY_QDRANT_URL=http://localhost:6333
# AGENT_MEMORY_QDRANT_API_KEY=
# AGENT_MEMORY_QDRANT_COLLECTION=atl_mcp_agent_memory

# === Server identity ===
# ORCHESTRATOR_NAME=atl-mcp-orchestrator
# ORCHESTRATOR_VERSION=0.1.0

# === Blueprint workflow (M4) ===
# TARGET_MODEL=host-delegated
# EVAL_VIEW_ENABLED=false

# === Milestone feature flags ===
# Each MILESTONE_N_ENABLED flag remains as a rollback control. Completed v1
# features default on; set a flag false only to hide that surface temporarily.
# MILESTONE_4_ENABLED=true
# MILESTONE_5_ENABLED=true
# MILESTONE_6A_ENABLED=true
# MILESTONE_6B_ENABLED=true
# MILESTONE_6C_ENABLED=true
# MILESTONE_7_ENABLED=true
# MILESTONE_8_ENABLED=true
# MILESTONE_9_ENABLED=true
# MILESTONE_10_ENABLED=true
# MILESTONE_11_ENABLED=true
# PERSISTENT_AGENT_MEMORY_ENABLED=true
